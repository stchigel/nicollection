# ──────────────────────────────────────────────────────────────────────────────
# nicollection — environment variables
#
# Copy this file to .env and fill in the values for your Firebase project.
# .env is gitignored and must NEVER be committed to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Firebase project configuration (get these from Firebase Console → Project settings)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Set to "true" to connect to the local Firebase Emulator Suite instead of production.
# Emulator ports are defined in firebase.json:
#   Firestore → localhost:8080
#   Auth      → localhost:9099
#   UI        → localhost:4000
VITE_USE_EMULATOR=false
